AIRFLOW_IMAGE_NAME=dockerhub.vnpost.vn/airflow-churn:1.0.0
AIRFLOW_UID=1000
_AIRFLOW_WWW_USER_USERNAME=vnp_ds_churn
_AIRFLOW_WWW_USER_PASSWORD=dsc@2026

# Thu muc tren Host
# DATA_DIR: duong dan TREN HOST, dung de mount vao container thanh /churn_data
DATA_DIR=/data/churn_prediction/ftp_churn
# Cac bien sau la duong dan BEN TRONG CONTAINER (sau khi duoc mount tu DATA_DIR)
INCOMING_DIR=/churn_data/churn_de
LABEL_INCOMING_DIR=/churn_data/label_de
LABEL_SCHEMA=Label
RULE_LABEL_FALLBACK_TARGET_CHURN_RATE=0.15
RULE_LABEL_UNCERTAIN_BAND_RATE=0.20

# Cau hinh nguong van hanh churn:
# - percentile: chon top X% khach co score cao nhat, phu hop khi muon giu so luong lead on dinh theo nang luc CSKH.
# - probability: cat theo xac suat model >= nguong, phu hop khi muon risk_flag co y nghia xac suat; so luong lead co the thay doi theo thang.
# - Neu muon ep nguong proba co dinh thi bo comment dong duoi; mac dinh de model tu persist threshold tu walk-forward/final holdout.
CHURN_OPERATING_MODE=probability
# CHURN_OPERATING_PROBABILITY_THRESHOLD=0.35

SAVED_DIR=/churn_process/saved_data
FAIL_DIR=/churn_process/fail_ingest
LOGS_DIR=/logs/ingest
# Cau hinh DB ung dung (Churn DB)
PG_HOST=172.16.2.142
PG_PORT=25432
PG_DB=churn_prediction
PG_USER=cpuser
PG_PW=cp123456
