AIRFLOW_IMAGE_NAME=dockerhub.vnpost.vn/airflow-churn:1.0.0
AIRFLOW_UID=1000
_AIRFLOW_WWW_USER_USERNAME=vnp_ds_churn
_AIRFLOW_WWW_USER_PASSWORD=dsc@2026

# Thu muc tren Host
# DATA_DIR: duong dan TREN HOST, dung de mount vao container thanh /churn_data
DATA_DIR=/data/churn_prediction/ftp_churn
# Cac bien sau la duong dan BEN TRONG CONTAINER (sau khi duoc mount tu DATA_DIR)
INCOMING_DIR=/churn_data/churn_de
LABEL_INCOMING_DIR=/churn_data/label_de
LABEL_SCHEMA=Label
RULE_LABEL_FALLBACK_TARGET_CHURN_RATE=0.15
RULE_LABEL_UNCERTAIN_BAND_RATE=0.20

# Cau hinh rule-label theo PL1:
# - Frequency/revenue warning/high bam theo Phu luc 01 muc I.
# - SINGLE_WARNING_AS_POSITIVE=true nghia la 1 tieu chi canh bao du kich hoat rule-positive theo PL1.
# - Neu sau nay thay label qua nhieu/noisy, co the doi SINGLE_WARNING_AS_POSITIVE=false de chi giu single warning o audit-only.
CHURN_PL1_FREQUENCY_DROP_WARNING=0.20
CHURN_PL1_FREQUENCY_DROP_HIGH=0.40
CHURN_PL1_REVENUE_DROP_WARNING=0.15
CHURN_PL1_REVENUE_DROP_HIGH=0.35
CHURN_PL1_MIN_BASE_ITEM=1.0
CHURN_PL1_MIN_BASE_REVENUE=0.0
CHURN_PL1_SINGLE_WARNING_AS_POSITIVE=true

# Mapping ser_Z -> nhom nguong recency PL1 muc II.
# C/R: buu chinh truyen thong; E/P: logistics noi dia; L/U: logistics quoc te.
# M/Q hien chua co mapping ro trong file san pham nen de unknown, nguong default 60 ngay.
CHURN_PL1_SERVICE_FAMILY_C=postal_traditional
CHURN_PL1_SERVICE_FAMILY_E=domestic_logistics
CHURN_PL1_SERVICE_FAMILY_M=unknown
CHURN_PL1_SERVICE_FAMILY_P=domestic_logistics
CHURN_PL1_SERVICE_FAMILY_R=postal_traditional
CHURN_PL1_SERVICE_FAMILY_U=international_logistics
CHURN_PL1_SERVICE_FAMILY_L=international_logistics
CHURN_PL1_SERVICE_FAMILY_Q=unknown
CHURN_PL1_RECENCY_POSTAL_DAYS=90
CHURN_PL1_RECENCY_DOMESTIC_LOGISTICS_DAYS=45
CHURN_PL1_RECENCY_INTERNATIONAL_LOGISTICS_DAYS=60
CHURN_PL1_RECENCY_VALUE_ADDED_DAYS=120
CHURN_PL1_RECENCY_UNKNOWN_DAYS=60

# Cau hinh business Churn Score theo PL2:
# business_churn_score = R*0.35 + F*0.30 + M*0.25 + VOC*0.10, tinh tren feature window T.
# R/F/M/VOC component score nam trong thang 1-5, diem cang cao thi rui ro cang lon.
CHURN_PL2_WEIGHT_R=0.35
CHURN_PL2_WEIGHT_F=0.30
CHURN_PL2_WEIGHT_M=0.25
CHURN_PL2_WEIGHT_VOC=0.10
CHURN_PL2_NORMALIZE_WEIGHTS=true

# Nguong R_score theo service_family. LOW_DAYS tuong ung diem thap, HIGH_DAYS tuong ung diem rui ro cao.
# Mapping service_family mac dinh dung chung voi PL1; neu can override rieng PL2 thi them CHURN_PL2_SERVICE_FAMILY_<Z>.
CHURN_PL2_R_POSTAL_TRADITIONAL_LOW_DAYS=20
CHURN_PL2_R_POSTAL_TRADITIONAL_HIGH_DAYS=45
CHURN_PL2_R_DOMESTIC_LOGISTICS_LOW_DAYS=10
CHURN_PL2_R_DOMESTIC_LOGISTICS_HIGH_DAYS=25
CHURN_PL2_R_INTERNATIONAL_LOGISTICS_LOW_DAYS=20
CHURN_PL2_R_INTERNATIONAL_LOGISTICS_HIGH_DAYS=40
CHURN_PL2_R_VALUE_ADDED_LOW_DAYS=30
CHURN_PL2_R_VALUE_ADDED_HIGH_DAYS=60
CHURN_PL2_R_UNKNOWN_LOW_DAYS=15
CHURN_PL2_R_UNKNOWN_HIGH_DAYS=60

# F_score: diem cao khi tan suat giao dich thap.
CHURN_PL2_F_SCORE_1_MIN=20
CHURN_PL2_F_SCORE_2_MIN=10
CHURN_PL2_F_SCORE_3_MIN=5
CHURN_PL2_F_SCORE_4_MIN=2

# M_score: diem cao khi doanh thu thap so voi binh quan nhom service_family trong cung window_end.
CHURN_PL2_M_SCORE_1_MIN_RATIO=1.20
CHURN_PL2_M_SCORE_2_MIN_RATIO=0.90
CHURN_PL2_M_SCORE_3_MIN_RATIO=0.60
CHURN_PL2_M_SCORE_4_MIN_RATIO=0.30
CHURN_PL2_VOC_DEFAULT_SCORE=3.0

# Cau hinh sample weight khi train:
# - Mac dinh de neutral (=1.00, recency=false) de khong tu chen gia dinh khi chua calibrate.
# - Chi giam audit-only / tang actual-positive / bat recency sau khi co bang chung tu walk-forward hoac doi soat CSKH.
# - Normalize giu mean weight ~= 1 neu sau nay bat weighting, tranh lam training scale bi doi qua manh.
CHURN_LABEL_AUDIT_ONLY_SAMPLE_WEIGHT=1.00
CHURN_LABEL_RULE_POSITIVE_SAMPLE_WEIGHT=1.00
CHURN_LABEL_RULE_NEGATIVE_SAMPLE_WEIGHT=1.00
CHURN_LABEL_ACTUAL_POSITIVE_SAMPLE_WEIGHT=1.00
CHURN_LABEL_ACTUAL_AND_RULE_POSITIVE_SAMPLE_WEIGHT=1.00
CHURN_RECENCY_WEIGHT_ENABLED=false
CHURN_RECENCY_WEIGHT_HALFLIFE_MONTHS=6
CHURN_RECENCY_WEIGHT_MIN=0.35
CHURN_RECENCY_WEIGHT_MAX=2.50
CHURN_SAMPLE_WEIGHT_NORMALIZE=true

# Cho XGBoost/Optuna tu thu cac bo sample-weight tinh tren walk-forward.
# Neutral 1.0 van nam trong grid, nen model co the chon lai hanh vi cu neu weighting khong co loi.
MAIN_XGB_OPTUNA_TUNE_SAMPLE_WEIGHTS=true
MAIN_XGB_OPTUNA_AUDIT_WEIGHT_CHOICES=0,0.1,0.2,0.5,1.0
MAIN_XGB_OPTUNA_ACTUAL_POSITIVE_WEIGHT_CHOICES=1.0,1.25,1.5
MAIN_XGB_OPTUNA_ACTUAL_AND_RULE_WEIGHT_CHOICES=1.0,1.25,1.5
MAIN_XGB_OPTUNA_TUNE_RECENCY_WEIGHT=true
MAIN_XGB_OPTUNA_RECENCY_ENABLED_CHOICES=false,true
MAIN_XGB_OPTUNA_RECENCY_HALFLIFE_CHOICES=3,6,9,12

# XGBoost max_delta_step giup on dinh cap nhat leaf khi class imbalance nang.
# 0 = tat co che nay; Optuna se tu chon trong grid duoi.
MAIN_XGB_MAX_DELTA_STEP=0
MAIN_XGB_OPTUNA_TUNE_MAX_DELTA_STEP=true
MAIN_XGB_OPTUNA_MAX_DELTA_STEP_CHOICES=0,1,3,5,7,10

# Learning rate scheduler cho XGBoost:
# - Optuna van chon learning_rate ban dau.
# - Scheduler lam learning_rate giam dan theo boosting round, tranh giu eta co dinh suot training.
# - Doi MAIN_XGB_LR_SCHEDULE=constant neu muon quay lai hanh vi cu.
MAIN_XGB_LR_SCHEDULE=cosine_decay
MAIN_XGB_LR_SCHEDULE_FINAL_FRACTION=0.10
MAIN_XGB_LR_SCHEDULE_MIN_RATE=0.0005
MAIN_XGB_OPTUNA_TUNE_LR_SCHEDULE=true
MAIN_XGB_OPTUNA_LR_SCHEDULE_CHOICES=cosine_decay,exponential_decay,linear_decay
MAIN_XGB_OPTUNA_LR_FINAL_FRACTION_CHOICES=0.05,0.10,0.20,0.35

# Cau hinh nguong van hanh churn:
# - percentile: chon top X% khach co score cao nhat, phu hop khi muon giu so luong lead on dinh theo nang luc CSKH.
# - probability: cat theo xac suat model >= nguong, phu hop khi muon risk_flag co y nghia xac suat; so luong lead co the thay doi theo thang.
# - Neu muon ep nguong proba co dinh thi bo comment dong duoi; mac dinh de model tu persist threshold tu walk-forward/final holdout.
CHURN_OPERATING_MODE=probability
# CHURN_OPERATING_PROBABILITY_THRESHOLD=0.35

SAVED_DIR=/churn_process/saved_data
FAIL_DIR=/churn_process/fail_ingest
LOGS_DIR=/logs/ingest
# Cau hinh DB ung dung (Churn DB)
PG_HOST=172.16.2.142
PG_PORT=25432
PG_DB=churn_prediction
PG_USER=cpuser
PG_PW=cp123456
