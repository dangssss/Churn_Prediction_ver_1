AIRFLOW_IMAGE_NAME=dockerhub.vnpost.vn/airflow-churn:1.0.0
AIRFLOW_UID=1000
_AIRFLOW_WWW_USER_USERNAME=vnp_ds_churn
_AIRFLOW_WWW_USER_PASSWORD=dsc@2026

# Thu muc tren Host
# DATA_DIR: duong dan TREN HOST, dung de mount vao container thanh /churn_data
DATA_DIR=/data/churn_prediction/ftp_churn
# Cac bien sau la duong dan BEN TRONG CONTAINER (sau khi duoc mount tu DATA_DIR)
INCOMING_DIR=/churn_data/churn_de
LABEL_INCOMING_DIR=/churn_data/label_de
LABEL_SCHEMA=Label
RULE_LABEL_FALLBACK_TARGET_CHURN_RATE=0.15
RULE_LABEL_UNCERTAIN_BAND_RATE=0.20

# Cau hinh sample weight khi train:
# - Mac dinh de neutral (=1.00, recency=false) de khong tu chen gia dinh khi chua calibrate.
# - Chi giam audit-only / tang actual-positive / bat recency sau khi co bang chung tu walk-forward hoac doi soat CSKH.
# - Normalize giu mean weight ~= 1 neu sau nay bat weighting, tranh lam training scale bi doi qua manh.
CHURN_LABEL_AUDIT_ONLY_SAMPLE_WEIGHT=1.00
CHURN_LABEL_RULE_POSITIVE_SAMPLE_WEIGHT=1.00
CHURN_LABEL_RULE_NEGATIVE_SAMPLE_WEIGHT=1.00
CHURN_LABEL_ACTUAL_POSITIVE_SAMPLE_WEIGHT=1.00
CHURN_LABEL_ACTUAL_AND_RULE_POSITIVE_SAMPLE_WEIGHT=1.00
CHURN_RECENCY_WEIGHT_ENABLED=false
CHURN_RECENCY_WEIGHT_HALFLIFE_MONTHS=6
CHURN_RECENCY_WEIGHT_MIN=0.35
CHURN_RECENCY_WEIGHT_MAX=2.50
CHURN_SAMPLE_WEIGHT_NORMALIZE=true

# Cho XGBoost/Optuna tu thu cac bo sample-weight tinh tren walk-forward.
# Neutral 1.0 van nam trong grid, nen model co the chon lai hanh vi cu neu weighting khong co loi.
MAIN_XGB_OPTUNA_TUNE_SAMPLE_WEIGHTS=true
MAIN_XGB_OPTUNA_AUDIT_WEIGHT_CHOICES=0,0.1,0.2,0.5,1.0
MAIN_XGB_OPTUNA_ACTUAL_POSITIVE_WEIGHT_CHOICES=1.0,1.25,1.5
MAIN_XGB_OPTUNA_ACTUAL_AND_RULE_WEIGHT_CHOICES=1.0,1.25,1.5
MAIN_XGB_OPTUNA_TUNE_RECENCY_WEIGHT=true
MAIN_XGB_OPTUNA_RECENCY_ENABLED_CHOICES=false,true
MAIN_XGB_OPTUNA_RECENCY_HALFLIFE_CHOICES=3,6,9,12

# Cau hinh nguong van hanh churn:
# - percentile: chon top X% khach co score cao nhat, phu hop khi muon giu so luong lead on dinh theo nang luc CSKH.
# - probability: cat theo xac suat model >= nguong, phu hop khi muon risk_flag co y nghia xac suat; so luong lead co the thay doi theo thang.
# - Neu muon ep nguong proba co dinh thi bo comment dong duoi; mac dinh de model tu persist threshold tu walk-forward/final holdout.
CHURN_OPERATING_MODE=probability
# CHURN_OPERATING_PROBABILITY_THRESHOLD=0.35

SAVED_DIR=/churn_process/saved_data
FAIL_DIR=/churn_process/fail_ingest
LOGS_DIR=/logs/ingest
# Cau hinh DB ung dung (Churn DB)
PG_HOST=172.16.2.142
PG_PORT=25432
PG_DB=churn_prediction
PG_USER=cpuser
PG_PW=cp123456
