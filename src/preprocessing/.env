ENVIRONMENT=development
DEBUG=false

PG_HOST=172.16.2.142
PG_PORT=25432
PG_DB=churn_prediction
PG_USER=cpuser
PG_PW=cp123456
DATABASE_URL=postgresql+psycopg2://cpuser:cp123456@172.16.2.142:25432/churn_prediction

DB_HOST=172.16.2.142
DB_PORT=25432
DB_USER=cpuser
DB_PASSWORD=cp123456
DB_NAME=churn_prediction
DB_DRIVER=psycopg2

FEATURE_SCHEMA=data_window
STATIC_SCHEMA=data_static
STATIC_TABLE=cus_lifetime

WINDOW_SIZES_MIN=3
WINDOW_SIZES_MAX=0
ENABLE_WINDOW_OPTIMIZATION=true
RECOMPUTE_LAST_N=2
ENABLE_STATIC_FEATURES=true
STATIC_DATA_START=2025-01-01
KEEP_WINDOW_HISTORY=2
BATCH_INSERT_SIZE=5
PARALLEL_RENDER=true
WINDOW_MAX_WORKERS=4

MONTH_CHUNK_SIZE=2
WINDOW_GROUP_SIZE=2
CHECKPOINT=

LOG_LEVEL=DEBUG
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DIR=/logs/preprocessing
LOG_FILE=true
LOG_CONSOLE=true
