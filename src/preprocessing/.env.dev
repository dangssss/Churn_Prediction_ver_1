ENVIRONMENT=development
DEBUG=false

PG_HOST=172.20.0.65
PG_PORT=5433
PG_DB=cpuser
PG_USER=cpuser
PG_PW=db12345
DATABASE_URL=postgresql+psycopg2://cpuser:db12345@172.20.0.65:5433/cpuser

DB_HOST=172.20.0.65
DB_PORT=5433
DB_USER=cpuser
DB_PASSWORD=db12345
DB_NAME=cpuser
DB_DRIVER=psycopg2

FEATURE_SCHEMA=data_window
STATIC_SCHEMA=data_static
STATIC_TABLE=cus_lifetime

WINDOW_SIZES_MIN=3
WINDOW_SIZES_MAX=0
ENABLE_WINDOW_OPTIMIZATION=true
RECOMPUTE_LAST_N=2
ENABLE_STATIC_FEATURES=true
STATIC_DATA_START=2025-01-01
KEEP_WINDOW_HISTORY=2
BATCH_INSERT_SIZE=5
PARALLEL_RENDER=false

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DIR=logs
LOG_FILE=true
LOG_CONSOLE=true
